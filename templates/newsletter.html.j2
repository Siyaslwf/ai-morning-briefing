<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{{ content.headline }}</title>
  <style type="text/css">
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; display: block; }
    body { margin: 0; padding: 0; background-color: #f1f5f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
    h1, h2, h3, h4 { margin: 0; padding: 0; line-height: 1.3; }
    p { margin: 0; padding: 0; }
    a { color: #6366f1; text-decoration: none; }
    a:hover { text-decoration: underline; }

    @media only screen and (max-width: 620px) {
      .email-wrapper  { width: 100% !important; }
      .email-body     { padding: 12px !important; }
      .hpad           { padding-left: 20px !important; padding-right: 20px !important; }
      .spad           { padding: 24px 20px !important; }
      h1.headline     { font-size: 24px !important; line-height: 1.3 !important; }
      .body-text      { font-size: 15px !important; }
      .money-card     { display: block !important; width: 100% !important; }
      .hide-mobile    { display: none !important; }
      .img-block img  { width: 100% !important; height: auto !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f1f5f9;">

<!-- Hidden preview text -->
<div style="display:none;font-size:1px;color:#f1f5f9;line-height:1px;max-height:0;overflow:hidden;">
  {{ content.preview_text }}&nbsp;&#847;&nbsp;&#847;&nbsp;&#847;&nbsp;&#847;
</div>

<!-- Outer -->
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f1f5f9;">
<tr><td align="center" style="padding:20px 10px;">

  <!-- Card -->
  <table class="email-wrapper" role="presentation" border="0" cellpadding="0" cellspacing="0" width="600"
         style="max-width:600px;width:100%;background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 32px rgba(0,0,0,0.10);">

    <!-- ▌HEADER -->
    <tr>
      <td style="background:#0f172a;padding:32px 40px 28px;text-align:center;" class="hpad">
        <p style="font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#6366f1;margin-bottom:12px;">
          &#9889; THE AI BRIEFING &#9889;
        </p>
        <p style="font-size:11px;color:#64748b;margin-bottom:16px;">
          Issue #{{ content.issue_number }} &nbsp;&#183;&nbsp; {{ content.date }}
        </p>
        <span style="display:inline-block;background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.3);color:#a5b4fc;font-size:12px;font-weight:600;padding:5px 14px;border-radius:6px;">
          {{ content.topic }}
        </span>
      </td>
    </tr>

    <!-- ▌HEADLINE + HOOK -->
    <tr>
      <td style="padding:36px 40px 28px;background:#ffffff;border-bottom:1px solid #f1f5f9;" class="spad">
        <h1 class="headline" style="font-size:28px;font-weight:800;color:#0f172a;line-height:1.25;letter-spacing:-0.5px;margin-bottom:16px;">
          {{ content.headline }}
        </h1>
        <p class="body-text" style="font-size:16px;line-height:1.7;color:#475569;border-left:3px solid #6366f1;padding-left:16px;">
          {{ content.hook }}
        </p>
      </td>
    </tr>

    <!-- ▌KEY INSIGHTS -->
    <tr>
      <td style="padding:32px 40px;background:#fafafa;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#6366f1;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;">
          &#10024; This Week's Key Insights
        </p>
        {% for item in content.key_insights %}
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="margin-bottom:{% if not loop.last %}14px{% else %}0{% endif %};">
          <tr>
            <td valign="top" width="36" style="padding-right:12px;padding-top:2px;">
              <div style="width:26px;height:26px;background:linear-gradient(135deg,#6366f1,#818cf8);border-radius:7px;text-align:center;line-height:26px;color:#fff;font-size:11px;font-weight:800;">
                {{ item.number }}
              </div>
            </td>
            <td valign="top">
              <p style="font-size:14px;font-weight:700;color:#0f172a;margin-bottom:3px;">{{ item.title }}</p>
              <p class="body-text" style="font-size:14px;line-height:1.6;color:#64748b;">{{ item.body }}</p>
            </td>
          </tr>
        </table>
        {% endfor %}
      </td>
    </tr>

    <!-- ▌DEEP DIVE -->
    <tr>
      <td style="padding:32px 40px;background:#ffffff;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#6366f1;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;">
          &#128269; Deep Dive
        </p>
        {% for para in content.deep_dive %}
        <p class="body-text" style="font-size:15px;line-height:1.75;color:#334155;margin-bottom:{% if not loop.last %}14px{% else %}0{% endif %};">
          {{ para }}
        </p>
        {% endfor %}
      </td>
    </tr>

    <!-- ▌AI ILLUSTRATION -->
    {% if images.illustration_b64 %}
    <tr>
      <td style="padding:0 40px 28px;background:#ffffff;" class="hpad">
        <div class="img-block" style="border-radius:10px;overflow:hidden;border:1px solid #e2e8f0;background:#0f172a;line-height:0;">
          <img src="data:image/png;base64,{{ images.illustration_b64 }}"
               alt="AI illustration: {{ content.topic }}"
               width="520" height="auto"
               style="width:100%;max-width:520px;height:auto;display:block;" />
        </div>
      </td>
    </tr>
    {% endif %}

    <!-- ▌MAKE MONEY WITH AI (new section) -->
    {% if content.money_with_ai %}
    <tr>
      <td style="padding:32px 40px;background:#0f172a;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#22c55e;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;">
          &#128176; Make Money With AI
        </p>
        <p style="font-size:12px;color:#64748b;margin-bottom:20px;">Three ways to earn or save time from this week's development</p>
        {% for m in content.money_with_ai %}
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="margin-bottom:{% if not loop.last %}14px{% else %}0{% endif %};background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;overflow:hidden;">
          <tr>
            <td style="padding:16px 18px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td>
                    <p style="font-size:14px;font-weight:700;color:#ffffff;margin-bottom:6px;">{{ m.method }}</p>
                    <p style="font-size:13px;line-height:1.6;color:#94a3b8;margin-bottom:10px;">{{ m.how }}</p>
                    <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding-right:12px;">
                          <span style="font-size:11px;font-weight:600;color:#22c55e;background:rgba(34,197,94,0.12);padding:3px 9px;border-radius:4px;">
                            {{ m.earning_potential }}
                          </span>
                        </td>
                        <td>
                          <span style="font-size:11px;color:#64748b;">Effort: {{ m.effort }}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
        {% endfor %}
      </td>
    </tr>
    {% endif %}

    <!-- ▌TRY THIS TODAY (new section) -->
    {% if content.implement_today %}
    <tr>
      <td style="padding:0 40px 28px;background:#0f172a;" class="hpad">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="background:linear-gradient(135deg,#166534,#15803d);border-radius:12px;overflow:hidden;">
          <tr>
            <td style="padding:22px 24px;">
              <p style="font-size:11px;font-weight:700;color:#bbf7d0;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;">
                &#9889; Try This Today
              </p>
              <p style="font-size:16px;font-weight:700;color:#ffffff;margin-bottom:8px;line-height:1.4;">
                {{ content.implement_today.action }}
              </p>
              <p style="font-size:13px;color:#bbf7d0;margin-bottom:14px;line-height:1.5;">
                <strong>Outcome:</strong> {{ content.implement_today.outcome }}
              </p>
              <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding-right:16px;">
                    <span style="font-size:12px;color:#86efac;">&#128336; {{ content.implement_today.time_needed }}</span>
                  </td>
                  <td>
                    <a href="{{ content.implement_today.tool_url }}"
                       style="display:inline-block;background:#ffffff;color:#166534;font-size:12px;font-weight:700;padding:8px 16px;border-radius:6px;text-decoration:none;">
                      Open {{ content.implement_today.tool }} &#8594;
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
    {% endif %}

    <!-- ▌STAT CHART -->
    {% if images.chart_b64 %}
    <tr>
      <td style="padding:28px 40px;background:#ffffff;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#6366f1;letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;">
          &#128202; By The Numbers
        </p>
        <div class="img-block" style="border-radius:10px;overflow:hidden;border:1px solid #e2e8f0;background:#fafafa;padding:14px;line-height:0;">
          <img src="data:image/png;base64,{{ images.chart_b64 }}"
               alt="Stats chart"
               width="488" height="auto"
               style="width:100%;max-width:488px;height:auto;display:block;" />
        </div>
      </td>
    </tr>
    {% endif %}

    <!-- ▌TOOL SPOTLIGHT -->
    <tr>
      <td style="padding:32px 40px;background:#1e1b4b;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#a5b4fc;letter-spacing:2px;text-transform:uppercase;margin-bottom:20px;">
          &#128293; Tool Spotlight
        </p>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
          <tr>
            <td valign="top" width="54" style="padding-right:14px;">
              <div style="width:44px;height:44px;background:rgba(99,102,241,0.3);border:1px solid rgba(99,102,241,0.5);border-radius:12px;text-align:center;line-height:44px;font-size:22px;">
                {{ content.tools_spotlight.emoji }}
              </div>
            </td>
            <td valign="top">
              <p style="font-size:17px;font-weight:800;color:#ffffff;margin-bottom:4px;">{{ content.tools_spotlight.name }}</p>
              <p style="font-size:13px;color:#a5b4fc;margin-bottom:8px;font-weight:500;">{{ content.tools_spotlight.tagline }}</p>
              <p style="font-size:13px;line-height:1.6;color:#c7d2fe;margin-bottom:14px;">{{ content.tools_spotlight.why_it_matters }}</p>
              <a href="{{ content.tools_spotlight.url }}"
                 style="display:inline-block;background:#6366f1;color:#ffffff;font-size:12px;font-weight:700;padding:9px 18px;border-radius:8px;text-decoration:none;">
                Check it out &#8594;
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- ▌QUICK BITES -->
    <tr>
      <td style="padding:32px 40px;background:#fafafa;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#6366f1;letter-spacing:2px;text-transform:uppercase;margin-bottom:18px;">
          &#9889; Quick Bites
        </p>
        {% for bite in content.quick_bites %}
        {% set tl = bite.tag | lower | replace(' ', '') %}
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="margin-bottom:{% if not loop.last %}12px{% else %}0{% endif %};background:#ffffff;border-radius:10px;border:1px solid #e2e8f0;">
          <tr>
            <td style="padding:13px 15px;">
              <span style="display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:5px;
                {% if 'news' in tl %}background:#dbeafe;color:#1d4ed8;
                {% elif 'tool' in tl %}background:#f3e8ff;color:#7e22ce;
                {% elif 'opport' in tl %}background:#dcfce7;color:#15803d;
                {% elif 'research' in tl %}background:#fef9c3;color:#a16207;
                {% elif 'fund' in tl %}background:#fef9c3;color:#a16207;
                {% else %}background:#e2e8f0;color:#475569;{% endif %}">{{ bite.tag }}</span>
              <a href="{{ bite.url }}" style="display:block;font-size:14px;font-weight:700;color:#0f172a;text-decoration:none;line-height:1.4;margin-bottom:4px;">
                {{ bite.title }}
              </a>
              <p style="font-size:13px;color:#64748b;line-height:1.5;margin:0;">{{ bite.summary }}</p>
            </td>
          </tr>
        </table>
        {% endfor %}
      </td>
    </tr>

    <!-- ▌RESOURCES -->
    <tr>
      <td style="padding:32px 40px;background:#ffffff;" class="spad">
        <p style="font-size:11px;font-weight:700;color:#6366f1;letter-spacing:2px;text-transform:uppercase;margin-bottom:18px;">
          &#128218; Worth Reading
        </p>
        {% for r in content.resources %}
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="margin-bottom:{% if not loop.last %}12px{% else %}0{% endif %};">
          <tr>
            <td valign="top" width="18" style="padding-right:10px;padding-top:5px;">
              <div style="width:6px;height:6px;background:#6366f1;border-radius:50%;margin-top:5px;"></div>
            </td>
            <td valign="top">
              <a href="{{ r.url }}" style="font-size:14px;font-weight:700;color:#0f172a;text-decoration:none;display:block;margin-bottom:2px;">{{ r.title }}</a>
              <p style="font-size:13px;color:#64748b;line-height:1.5;">{{ r.description }}</p>
            </td>
          </tr>
        </table>
        {% endfor %}
      </td>
    </tr>

    <!-- ▌CTA -->
    <tr>
      <td style="padding:0 40px 32px;background:#ffffff;" class="hpad">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%"
               style="background:linear-gradient(135deg,#6366f1,#818cf8);border-radius:14px;">
          <tr>
            <td style="padding:26px 24px;text-align:center;">
              <p style="font-size:20px;margin-bottom:8px;">&#128172;</p>
              <p style="font-size:15px;font-weight:700;color:#ffffff;margin-bottom:6px;line-height:1.4;">{{ content.cta }}</p>
              <p style="font-size:12px;color:#c7d2fe;">Hit reply — we read every message.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- ▌FOOTER -->
    <tr>
      <td style="padding:24px 40px 28px;background:#ffffff;text-align:center;border-top:1px solid #f1f5f9;" class="hpad">
        <p style="font-size:13px;font-weight:700;color:#0f172a;margin-bottom:4px;">The AI Briefing</p>
        <p style="font-size:12px;color:#94a3b8;line-height:1.6;margin-bottom:12px;">
          AI news, money moves, and practical tips — every week.
        </p>
        <p style="font-size:11px;color:#cbd5e1;">
          &copy; {{ content.date.split(',')[-1].strip() }} The AI Briefing &nbsp;&#183;&nbsp;
          <a href="mailto:{{ gmail_address }}" style="color:#94a3b8;text-decoration:underline;">Contact</a>
          &nbsp;&#183;&nbsp;
          <a href="#" style="color:#94a3b8;text-decoration:underline;">Unsubscribe</a>
        </p>
      </td>
    </tr>

  </table>
</td></tr>
</table>
</body>
</html>
